APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Where uploaded post/story/profile media is stored — read by
# GlobalFunction::saveFile/deleteFile/getItemBaseUrl (app/Models/GlobalFunction.php).
# One of: AWSS3, DOSPACE, PUBLIC. PUBLIC serves files straight off this
# server's disk with no CDN — fine for local dev, not for production.
FILES_STORAGE_LOCATION=DOSPACE

# DigitalOcean Spaces (config/filesystems.php 'digitalocean' disk). Region
# and endpoint must match where you created the Space, e.g. region "nyc3",
# endpoint "https://nyc3.digitaloceanspaces.com".
DO_SPACE_ACCESS_KEY_ID=
DO_SPACE_SECRET_ACCESS_KEY=
DO_SPACE_REGION=
DO_SPACE_BUCKET=
DO_SPACE_ENDPOINT=
# IMPORTANT: use the Space's CDN endpoint here (the one ending in
# .cdn.digitaloceanspaces.com from the "Enable CDN" toggle in the DO
# dashboard), NOT the raw origin URL — pointing this at the origin URL
# instead silently skips the CDN entirely while still "working".
DO_SPACE_URL=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Required for social login (see GlobalFunction::verifyGoogleIdToken /
# verifyAppleIdentityToken). If unset, Google login is refused outright and
# Apple login always fails — both fail closed, never silently unverified.
GOOGLE_OAUTH_CLIENT_ID=
APPLE_BUNDLE_ID=
APPLE_SERVICE_ID=

# RevenueCat — coin purchase verification (WalletController::buyCoins) and
# subscription state sync (RevenueCatWebhookController). RC_KIT_API_KEY is a
# secret API key from RevenueCat's dashboard (Project Settings > API Keys),
# RC_PROJECT_ID is your RevenueCat project id. REVENUECAT_WEBHOOK_SECRET is a
# string YOU make up and paste into RevenueCat's dashboard under
# Integrations > Webhooks as the "Authorization header value" — RevenueCat
# echoes it back on every webhook call, and that's the entire authenticity
# check (a static shared secret, not HMAC signing).
RC_KIT_API_KEY=
RC_PROJECT_ID=
REVENUECAT_WEBHOOK_SECRET=
